# Cloudflare R2 (S3-compatible) — copy to .env.local and fill in.
# These are SERVER-ONLY. Never prefix with NEXT_PUBLIC_.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# e.g. https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Optional: folder prefixes inside the bucket (defaults shown)
R2_PREFIX_RAW=raw
R2_PREFIX_ANNOTATIONS=annotations
R2_PREFIX_EXPORTS=exports
